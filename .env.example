# Discord Bot Token (必填)
# 從 Discord Developer Portal 取得
DISCORD_TOKEN=your-discord-bot-token-here

# Guild ID (選填，強烈建議私人 Bot 填寫)
# 填入後 Slash Command 即時生效，不需等待 1 小時
# 取得方式：Discord 開啟開發者模式 → 右鍵 Server → 複製 ID
GUILD_ID=

# FFmpeg 執行檔路徑 (選填)
# 預設使用系統 PATH 中的 ffmpeg
# 若有自訂安裝路徑，例如：FFMPEG_PATH=/usr/local/bin/ffmpeg
FFMPEG_PATH=ffmpeg

# 無人聆聽後自動離開的等待秒數 (選填，預設 300 秒 = 5 分鐘)
AUTO_DISCONNECT_SECONDS=300

# Queue 最大歌曲數 (選填，預設 100)
MAX_QUEUE_SIZE=100

# 單次 Playlist 最多匯入歌曲數 (選填，預設 50)
MAX_PLAYLIST_SONGS=50

# 預設啟動音量 (選填，0.0–1.0，預設 0.2 = 20%)
DEFAULT_VOLUME=0.2

# YouTube Cookies 檔案路徑 (選填)
# 用途：解決 YouTube HTTP 429（Too Many Requests）封鎖問題
# 步驟：
#   1. 安裝瀏覽器擴充套件 "Get cookies.txt LOCALLY"
#   2. 登入 YouTube，點擊套件圖示 → 匯出 youtube.com 的 cookies
#   3. 將 cookies.txt 放到本專案根目錄
#   4. 填入路徑如下：
# COOKIES_FILE=cookies.txt
COOKIES_FILE=

# Genius API Token (選填，用於 /lyrics 歌詞查詢)
# 申請步驟：
#   1. 前往 https://genius.com/developers
#   2. 點擊 New API Client，填寫任意 App 名稱與網址
#   3. 複製 Client Access Token（不是 Client Secret）
GENIUS_API_KEY=
