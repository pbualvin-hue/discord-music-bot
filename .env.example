# Discord Bot Token (必填)
# 從 Discord Developer Portal 取得
DISCORD_TOKEN=your-discord-bot-token-here

# Guild ID (選填，強烈建議私人 Bot 填寫)
# 填入後 Slash Command 即時生效，不需等待 1 小時
# 取得方式：Discord 開啟開發者模式 → 右鍵 Server → 複製 ID
GUILD_ID=

# FFmpeg 執行檔路徑 (選填)
# 預設使用系統 PATH 中的 ffmpeg
# 若有自訂安裝路徑，例如：FFMPEG_PATH=/usr/local/bin/ffmpeg
FFMPEG_PATH=ffmpeg

# 無人聆聽後自動離開的等待秒數 (選填，預設 300 秒 = 5 分鐘)
AUTO_DISCONNECT_SECONDS=300

# Queue 最大歌曲數 (選填，預設 100)
MAX_QUEUE_SIZE=100

# 單次 Playlist 最多匯入歌曲數 (選填，預設 50)
MAX_PLAYLIST_SONGS=50

# 預設啟動音量 (選填，0.0–1.0，預設 0.2 = 20%)
DEFAULT_VOLUME=0.2

# YouTube Cookies 檔案路徑 (選填)
# 用途：解決 YouTube 429 / 「Sign in to confirm you're not a bot」封鎖問題
# ⚠️ 正確匯出方式（用「登入中的一般分頁」匯出會被 YouTube 輪替失效）：
#   1. 安裝瀏覽器擴充套件 "Get cookies.txt LOCALLY"
#   2. 開「無痕視窗」登入 YouTube（建議用拋棄式帳號，勿用主帳號）
#   3. 點套件圖示 → 匯出 youtube.com 的 cookies → 存成 cookies.txt
#   4. 直接關掉無痕視窗，不要登出、不要再操作該視窗（否則 cookie 被輪替失效）
#   5. 將 cookies.txt 放到本專案根目錄，填入路徑：
# COOKIES_FILE=cookies.txt
COOKIES_FILE=

# YouTube 專用 HTTP Proxy (選填，機房 IP 被擋時用)
# 用途：把 YouTube 流量繞經住宅 IP（例如家裡 NAS 的反向通道），
#       讓 Oracle 這類機房主機不再被 YouTube 判定為機器人。
# 格式：http://host:port，例如反向通道在本機 8888 埠：
# YT_PROXY=http://127.0.0.1:8888
# 設定步驟見 PROXY_SETUP.md
YT_PROXY=

# Genius API Token (選填，用於 /lyrics 歌詞查詢)
# 申請步驟：
#   1. 前往 https://genius.com/developers
#   2. 點擊 New API Client，填寫任意 App 名稱與網址
#   3. 複製 Client Access Token（不是 Client Secret）
GENIUS_API_KEY=

# yt-dlp 更新通知頻道 ID (選填)
# 設定後，bot 會每天檢查 PyPI，有新版 yt-dlp 時自動發訊息到此頻道提醒你更新。
# 同一個新版本只通知一次。留空＝不啟用。
# 取得頻道 ID：Discord 設定 → 進階 → 開啟「開發者模式」，
#             然後右鍵目標頻道 → 複製頻道 ID。
YTDLP_NOTIFY_CHANNEL_ID=

# 檢查頻率（小時，選填，預設 24）
YTDLP_CHECK_INTERVAL_HOURS=24
